# Copy to .env and fill in. Used by docker-compose.prod.yml + deploy-swap.sh.

# --- Django ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=false
ALLOWED_HOSTS=weststreetbaptist.org,www.weststreetbaptist.org
CSRF_TRUSTED_ORIGINS=https://weststreetbaptist.org,https://www.weststreetbaptist.org
GUNICORN_WORKERS=3
TIME_ZONE=America/Denver

# --- Database ---
POSTGRES_DB=weststreet
POSTGRES_USER=weststreet
POSTGRES_PASSWORD=change-me

# --- Email notifications for form submissions (optional) ---
# Leave EMAIL_BACKEND on console to disable real sending.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@weststreetbaptist.org
CHURCH_NOTIFY_EMAIL=

# --- Container registry / deploy ---
GITHUB_REPO=kyle799/west-street-baptist
IMAGE_TAG=latest

# --- nginx ---
# conf.d.cloudflare (plain HTTP behind Cloudflare tunnel) is the default.
NGINX_PROFILE=conf.d.cloudflare
# Bind only to the Cloudflare tunnel / private interface if desired:
NGINX_BIND_IP=0.0.0.0
NGINX_HOST_PORT=80
